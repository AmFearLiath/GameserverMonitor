{
  "name": "game-monitoring",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.6.2",
  "scripts": {
    "dev:api": "pnpm --filter @gm/api dev",
    "dev:worker": "pnpm --filter @gm/worker dev",
    "dev:web": "pnpm --filter @gm/web dev",
    "db:migrate": "pnpm --filter @gm/db migrate",
    "db:seed": "pnpm --filter @gm/db seed",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@typescript-eslint/eslint-plugin": "^8.25.0",
    "@typescript-eslint/parser": "^8.25.0",
    "eslint": "^9.21.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "tsx": "^4.20.5",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}